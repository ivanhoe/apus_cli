name: {{ .AppName }}
options:
  bundleIdPrefix: com.{{ .BundleOrg }}
  deploymentTarget:
    iOS: "16.0"
  xcodeVersion: "15.0"
  createIntermediateGroups: true

packages:
  Apus:
{{- if eq .ApusPackageSource "local" }}
    path: "{{ .ApusPackagePath }}"
{{- else }}
    url: "{{ .ApusPackageURL }}"
    branch: "{{ .ApusPackageBranch }}"
{{- end }}

targets:
  {{ .AppName }}:
    type: application
    platform: iOS
    sources:
      - Sources
    dependencies:
      - package: Apus
        product: Apus
    settings:
      base:
        GENERATE_INFOPLIST_FILE: YES
        PRODUCT_BUNDLE_IDENTIFIER: com.{{ .BundleOrg }}.{{ .AppNameLower }}
        SWIFT_VERSION: 5.9
        CODE_SIGN_IDENTITY: "-"
        CODE_SIGNING_REQUIRED: "NO"
        OTHER_LDFLAGS: "$(inherited) -Xlinker -interposable"
